interface Loopback0
 ip address 172.16.2.1 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.0.54 255.255.255.252
 ip ospf network point-to-point
 no shutdown
!
interface Ethernet0/2
 ip address 10.0.0.58 255.255.255.252
 ip ospf network point-to-point
 no shutdown
!
interface Ethernet0/3
 description CLIENTE-HQ
 ip address 10.0.0.65 255.255.255.252
 no shutdown
!
interface Ethernet1/0
 description CLIENTE-BRANCH
 ip address 10.0.0.61 255.255.255.252
 no shutdown
!
interface Ethernet1/1
 no ip address
 shutdown
!
interface Ethernet1/2
 no ip address
 shutdown
!
interface Ethernet1/3
 no ip address
 shutdown
!
router ospf 20
 router-id 172.16.2.1
 network 10.0.0.52 0.0.0.3 area 0
 network 10.0.0.56 0.0.0.3 area 0
 network 172.16.2.1 0.0.0.0 area 0
!
router bgp 200
 bgp router-id 172.16.2.1
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.0.0.62 remote-as 65002
 neighbor 10.0.0.66 remote-as 65001
 neighbor 172.16.2.2 remote-as 200
 neighbor 172.16.2.2 update-source Loopback0
 neighbor 172.16.2.3 remote-as 200
 neighbor 172.16.2.3 update-source Loopback0
 neighbor 172.16.2.4 remote-as 200
 neighbor 172.16.2.4 update-source Loopback0
 neighbor 172.16.2.5 remote-as 200
 neighbor 172.16.2.5 update-source Loopback0
 !
 address-family ipv4
  neighbor 10.0.0.62 activate
  neighbor 10.0.0.66 activate
  neighbor 172.16.2.2 activate
  neighbor 172.16.2.2 next-hop-self
  neighbor 172.16.2.3 activate
  neighbor 172.16.2.3 next-hop-self
  neighbor 172.16.2.4 activate
  neighbor 172.16.2.4 next-hop-self
  neighbor 172.16.2.5 activate
  neighbor 172.16.2.5 next-hop-self
 exit-address-family
!
ip forward-protocol nd
ip ftp username dubuntu
ip ftp password 123456
ip http server
ip http secure-server
