interface Loopback0
 ip address 200.0.0.1 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.0.2 255.255.255.252
 no shutdown
!
interface Ethernet0/2
 no ip address
 no shutdown
!
interface Ethernet0/2.30
  encapsulation dot1q 30
  ip address 100.64.30.1 255.255.255.0
!
interface Ethernet0/2.40
  encapsulation dot1q 40
  ip address 100.64.40.1 255.255.255.0
! 
interface Ethernet1/0
 no ip address
 no shutdown
!
interface Ethernet1/0.50
  encapsulation dot1q 50
  ip address 100.64.50.1 255.255.255.0
!
interface Ethernet1/0.60
  encapsulation dot1q 60
  ip address 100.64.60.1 255.255.255.0
!
interface Ethernet0/3
 ip address 200.1.1.2 255.255.255.252
 no shutdown
!
ip forward-protocol nd
!
ip routing
!
ip http server
ip http secure-server

!Respaldo
ip route 192.168.0.0 255.255.0.0 200.1.1.1 150

!
ip route 0.0.0.0 0.0.0.0 10.0.0.1 1
!
ip route 0.0.0.0 0.0.0.0 200.1.1.1 200

! VTI: 

crypto isakmp policy 10
 encryption aes 256
 authentication pre-share
 group 14
exit 
!
crypto isakmp key secretkey address 200.0.0.6
!
crypto ipsec transform-set SET-VTI esp-aes 256 esp-sha-hmac
 mode tunnel
exit
!
crypto ipsec profile PERFIL-VTI
 set transform-set SET-VTI
exit
!
interface Tunnel0
 ip address 20.2.2.1 255.255.255.252 
 tunnel source Ethernet0/1
 tunnel destination 200.0.0.6
 tunnel protection ipsec profile PERFIL-VTI
exit
!

conf t
router ospf 1
 passive-interface default
 network 20.2.2.0 0.0.0.3 area 0
 network 100.64.0.0 0.0.255.255 area 0
 no passive-interface Tunnel0
exit 