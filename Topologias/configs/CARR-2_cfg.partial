!
interface Loopback0
 ip address 172.16.3.2 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.4.1 255.255.255.252
 ip ospf network point-to-point
!
interface Ethernet0/2
 no ip address
 shutdown
!
interface Ethernet1/0
 ip address 10.0.2.1 255.255.255.252
!
router ospf 30
 router-id 172.16.3.2
 network 10.0.4.0 0.0.0.3 area 0
 network 172.16.3.2 0.0.0.0 area 0
!
router bgp 300
 bgp router-id 172.16.3.2
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.0.2.2 remote-as 200
 neighbor 172.16.3.1 remote-as 300
 neighbor 172.16.3.1 update-source Loopback0
 neighbor 172.16.3.3 remote-as 300
 neighbor 172.16.3.3 update-source Loopback0
 !
 address-family ipv4
  neighbor 10.0.2.2 activate
  neighbor 172.16.3.1 activate
  neighbor 172.16.3.1 next-hop-self
  neighbor 172.16.3.3 activate
  neighbor 172.16.3.3 next-hop-self
 exit-address-family
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
