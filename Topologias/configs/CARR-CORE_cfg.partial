!
interface Loopback0
 ip address 172.16.3.3 255.255.255.255
!
interface Loopback1
 ip address 8.8.8.8 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.3.2 255.255.255.252
 ip ospf network point-to-point
!
interface Ethernet0/2
 no ip address
 shutdown
!
interface Ethernet0/3
 no ip address
 shutdown
!
interface Ethernet1/0
 ip address 10.0.4.2 255.255.255.252
 ip ospf network point-to-point
!
router ospf 30
 router-id 172.16.3.3
 network 10.0.3.0 0.0.0.3 area 0
 network 10.0.4.0 0.0.0.3 area 0
 network 172.16.3.3 0.0.0.0 area 0
!
router bgp 300
 bgp router-id 172.16.3.3
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 172.16.3.1 remote-as 300
 neighbor 172.16.3.1 update-source Loopback0
 neighbor 172.16.3.2 remote-as 300
 neighbor 172.16.3.2 update-source Loopback0
 !
 address-family ipv4
  network 8.8.8.8 mask 255.255.255.255
  neighbor 172.16.3.1 activate
  neighbor 172.16.3.1 next-hop-self
  neighbor 172.16.3.2 activate
  neighbor 172.16.3.2 next-hop-self
 exit-address-family
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
