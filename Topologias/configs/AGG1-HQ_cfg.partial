vlan 10
 no shut
!  
vlan 20
 no shut
!
int e0/3
 sw trun enc dot1q
 sw mode trunk
 sw trunk allow vlan 10,20
!
int e1/0
 sw trun enc dot1q
 sw mode trunk
 sw trunk allow vlan 10,20
!
int e0/2
 no sw
 ip add 20.0.0.1 255.255.255.252
!
int e0/1
 no sw
 ip add 20.0.0.9 255.255.255.252
!
ip routing
!
router ospf 1
 router-id 20.1.1.5
 network 20.0.0.0 0.0.0.3 area 0
 network 20.0.0.8 0.0.0.3 area 0
 network 192.168.10.0 0.0.0.255 area 0
 network 192.168.20.0 0.0.0.255 area 0
 passive-interface e0/3
 passive-interface e1/0
 passive-interface vlan 10
 passive-interface vlan 20
!
int vlan 10
 ip add 192.168.10.253 255.255.255.0
 vrrp 10 priority 150
 vrrp 10 ip 192.168.10.254
!
int vlan 20
 ip add 192.168.20.253 255.255.255.0
 vrrp 20 priority 100
 vrrp 20 ip 192.168.20.254 
!
