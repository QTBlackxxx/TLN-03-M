!
interface Loopback0
 ip address 172.16.2.3 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.0.33 255.255.255.252
!
interface Ethernet0/2
 ip address 10.0.0.26 255.255.255.252
!
interface Ethernet0/3
 ip address 10.0.0.41 255.255.255.252
!
router ospf 1
 router-id 172.16.2.3
 network 10.0.0.0 0.0.0.255 area 0
 network 172.16.2.0 0.0.0.255 area 0
!
router bgp 200
 bgp router-id 172.16.2.3
 bgp log-neighbor-changes
 no bgp default ipv4-unicast
 neighbor 10.0.0.25 remote-as 100
 neighbor 172.16.2.1 remote-as 200
 neighbor 172.16.2.1 update-source Loopback0
 neighbor 172.16.2.2 remote-as 200
 neighbor 172.16.2.2 update-source Loopback0
 neighbor 172.16.2.4 remote-as 200
 neighbor 172.16.2.4 update-source Loopback0
 neighbor 172.16.2.5 remote-as 200
 neighbor 172.16.2.5 update-source Loopback0
 !
 address-family ipv4
  neighbor 10.0.0.25 activate
  neighbor 172.16.2.1 activate
  neighbor 172.16.2.2 activate
  neighbor 172.16.2.4 activate
  neighbor 172.16.2.5 activate
 exit-address-family
!
ip forward-protocol nd
!
!
ip ftp username dubuntu
ip ftp password 123456
